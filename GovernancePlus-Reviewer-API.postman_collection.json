{
  "info": {
    "name": "GovernancePlus Reviewer API",
    "description": "Covers reviewer-web and reviewer-mule -- both expose the same REST surface by design (reviewer-mule mirrors reviewer-web's endpoints; see reviewer-mule/pom.xml's top comment for the documented deltas). Set the `baseUrl` variable to whichever backend you're running: reviewer-web defaults to port 8081 (reviewer-web/src/main/resources/application.yml), reviewer-mule also currently defaults to port 8081 (reviewer-mule/src/main/mule/global.xml's http.port property).\n\nKnown differences when pointed at reviewer-mule instead of reviewer-web:\n- GET /api/reviews/{jobId} doesn't exist on reviewer-mule (no job history/polling -- POST /api/reviews runs synchronously and returns the report directly there).\n- Rules CRUD on reviewer-mule is backed by an in-memory H2 database seeded from schema.sql, not the shared rules/rules.json file reviewer-web reads/writes -- the two backends do NOT share rule state.\n- Review runs on reviewer-mule currently read rules from rules/rules.json regardless (a known, flagged gap -- see reviewer-mule/src/main/mule/global.xml's comment on the rules.dir property), so a rule added via reviewer-mule's own POST /api/rules/xml is not yet visible to reviewer-mule's own POST /api/reviews.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "xmlRuleId",
      "value": "MULE039",
      "type": "string"
    },
    {
      "key": "pomRuleArtifactId",
      "value": "mule-amqp-connector",
      "type": "string"
    },
    {
      "key": "swaggerRuleId",
      "value": "SWAGGER-001",
      "type": "string"
    },
    {
      "key": "jobId",
      "value": "REPLACE_WITH_A_JOB_ID_FROM_SUBMIT_REVIEW_RESPONSE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Submit Review (server-side project path)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews"
              ]
            },
            "description": "Runs the deterministic rule engine against a project already on the server's filesystem. reviewer-web: async, returns {jobId, status, report: null, errorMessage: null} immediately -- poll GET /api/reviews/{jobId} for the result. reviewer-mule: synchronous, returns the full report directly.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectPath\": \"/absolute/path/to/a/mule/project/on/the/server\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Submit Review (zip upload)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews"
              ]
            },
            "description": "Upload a project zip instead of a server-side path. reviewer-web extracts to a temp dir; reviewer-mule extracts under /opt/mule/tmp (both zip-slip / zip-bomb guarded). Select a .zip file for the `file` form field before sending -- Postman can't pre-fill a file path for you.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Review Job (reviewer-web only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/reviews/{{jobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews",
                "{{jobId}}"
              ]
            },
            "description": "Poll a submitted review job's status/report. Set the `jobId` variable from a Submit Review response first. reviewer-web only -- this endpoint does not exist on reviewer-mule (no job history there; see collection description)."
          },
          "response": []
        }
      ]
    },
