    <flow name="update-pom-rule" doc:id="a3c56dbe-580c-4d4b-bc51-3deabe2f9925">

        <flow-ref name="require-admin" />
        <set-variable variableName="targetArtifactId" value="#[attributes.uriParams.artifactId]" />
        <set-variable variableName="newRule" value="#[payload]" />

        <choice>
            <when expression="#[isEmpty(vars.newRule.artifactId default '')]">
                <raise-error type="APP:BAD_REQUEST" description="artifactId must not be blank" />
            </when>
        </choice>

        <db:select config-ref="rules-db-config" target="existingTarget">
            <db:sql>SELECT COUNT(*) AS CNT FROM POM_RULES WHERE ARTIFACT_ID = :artifactId</db:sql>
            <db:input-parameters><![CDATA[#[{ artifactId: vars.targetArtifactId }]]]></db:input-parameters>
        </db:select>

        <choice>
            <when expression="#[vars.existingTarget[0].CNT == 0]">
                <raise-error type="APP:NOT_FOUND" description="#['Pom rule not found: ' ++ vars.targetArtifactId]" />
            </when>
        </choice>

        <choice>
            <when expression="#[vars.newRule.artifactId != vars.targetArtifactId]">
                <db:select config-ref="rules-db-config" target="existingNewId">
                    <db:sql>SELECT COUNT(*) AS CNT FROM POM_RULES WHERE ARTIFACT_ID = :artifactId</db:sql>
                    <db:input-parameters><![CDATA[#[{ artifactId: vars.newRule.artifactId }]]]></db:input-parameters>
                </db:select>
                <choice>
                    <when expression="#[vars.existingNewId[0].CNT > 0]">
                        <raise-error type="APP:CONFLICT" description="#['Pom rule already exists: ' ++ vars.newRule.artifactId]" />
                    </when>
                </choice>
            </when>
        </choice>

        <db:update config-ref="rules-db-config">
            <db:sql>UPDATE POM_RULES SET ARTIFACT_ID = :newArtifactId, MIN_VERSION = :minVersion, PROJECT_NAME_PATTERN = :projectNamePattern
                WHERE ARTIFACT_ID = :targetArtifactId</db:sql>
            <db:input-parameters><![CDATA[#[{
                newArtifactId: vars.newRule.artifactId,
                minVersion: (vars.newRule.minVersion default null),
                projectNamePattern: (vars.newRule.projectNamePattern default null),
                targetArtifactId: vars.targetArtifactId
            }]]]></db:input-parameters>
        </db:update>

        <set-payload value="#[vars.newRule]" mimeType="application/json" />

        <error-handler ref="api-error-handler" />
    </flow>

    <flow name="delete-pom-rule" doc:id="e0ccc25a-2b7f-4f39-802c-216841f14e1f">

        <flow-ref name="require-admin" />
        <set-variable variableName="targetArtifactId" value="#[attributes.uriParams.artifactId]" />

        <db:delete config-ref="rules-db-config" target="deletedCount">
